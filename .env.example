OAUTH2_AUTH_URL=https://example.com/oauth2/authorize
OAUTH2_TOKEN_URL=https://example.com/oauth2/token

TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_STREAMER_USERNAME=your_streamer_username
TWITCH_WEBHOOK_SECRET=replace_with_webhook_secret
TWITCH_BOT_REFRESH_TOKEN=your_refresh_token
